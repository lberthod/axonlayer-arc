# ---------------------------------------------------------------------------
# Backend configuration — Agent-to-Agent USDC Task Network
#
# Copy to `.env` and adjust values. Nothing is required for simulated mode.
# To move real USDC on Circle Arc (or any EVM chain), set WALLET_PROVIDER=onchain,
# generate wallets with `npm run wallets:generate`, fund them from the faucet,
# and set ONCHAIN_DRY_RUN=false.
# ---------------------------------------------------------------------------

# --- HTTP ------------------------------------------------------------------
PORT=3001

# --- Security --------------------------------------------------------------
# Comma-separated list of origins allowed by CORS. Use '*' only for dev.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Global rate limits (requests per window, per IP / uid).
RATE_LIMIT_GLOBAL=300
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_TASKS=30
RATE_LIMIT_TASKS_WINDOW_MS=60000
RATE_LIMIT_SIM=3
RATE_LIMIT_SIM_WINDOW_MS=60000
RATE_LIMIT_AUTH=10
RATE_LIMIT_AUTH_WINDOW_MS=60000

# Idempotency-Key cache TTL (ms). Client sends `Idempotency-Key: <8-128 chars>`
# on POST /api/tasks to safely retry without double-charging.
IDEMPOTENCY_TTL_MS=600000

# Pino log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info



# --- Wallet provider -------------------------------------------------------
# simulated -> in-memory ledger (safe default, fully offline)
# onchain   -> EVM JSON-RPC adapter that moves real ERC-20 USDC
WALLET_PROVIDER=onchain


# --- Network preset --------------------------------------------------------
# Built-in presets (RPC / chainId / USDC address):
#   arc-testnet   Circle Arc Testnet (USDC is the native gas asset)
#   arc           Circle Arc Mainnet
#   base-sepolia  Base Sepolia (Circle testnet faucet-supported)
#   base          Base Mainnet
ONCHAIN_NETWORK=arc-testnet


# --- On-chain overrides (optional) -----------------------------------------
# If set, these override the values from the preset above. Leave blank to
# use the preset defaults.
# ONCHAIN_RPC_URL=https://rpc.testnet.arc.network
# ONCHAIN_CHAIN_ID=6699
# ONCHAIN_USDC_ADDRESS=0x...

# Keep dryRun=true until you are ready to broadcast transactions.
# When true, transfers are NOT sent on-chain; only the ledger mirror is
# updated and transactions are tagged `onchain-dryrun`.
ONCHAIN_DRY_RUN=true

# Path (relative to backend/) of the per-agent wallets file.
# Produced by `npm run wallets:generate`. DO NOT COMMIT.
# ONCHAIN_WALLETS_FILE=src/data/wallets.json


# --- Pricing profile -------------------------------------------------------
# Scales all default agent payments. Use `nano` or `micro` when running on
# cheap chains like Arc where settlement is virtually free.
#   standard  client ≈ 0.005 USDC (default)
#   nano      client ≈ 0.0005 USDC (≈ 0.05 cent per task)
#   micro     client ≈ 0.00005 USDC (≈ 0.005 cent per task)
PRICING_PROFILE=nano

# Set to "false" to disable the dynamic, input-length-aware pricing engine.
# DYNAMIC_PRICING=true


# --- Agent selection -------------------------------------------------------
# Default strategy used by the agent registry.
#   price | score | score_price
AGENT_SELECTION=score_price


# --- Arc Blockchain Integration -------------------------------------------
# RPC endpoint for Arc testnet. Used for real balance checking.
# Default: https://testnet-rpc.arc.io
ARC_TESTNET_RPC=https://testnet-rpc.arc.io

# USDC contract address on Arc testnet
# Arc testnet USDC: 0x3600000000000000000000000000000000000000
ARC_USDC_CONTRACT=0x3600000000000000000000000000000000000000


# --- Auth (Firebase Admin) -------------------------------------------------
# Set AUTH_ENABLED=false to fully disable auth (open API, dev only).
AUTH_ENABLED=true

# Firebase project id (same as used by the web client).
FIREBASE_PROJECT_ID=agenthubarc

# Path (relative to backend/) to a Firebase service account JSON file.
# Leave empty if you rely on GOOGLE_APPLICATION_CREDENTIALS / ADC.
FIREBASE_SERVICE_ACCOUNT=firebase-service-account.json

# Comma-separated list of emails that are auto-promoted to admin on first login.
ADMIN_EMAILS=me@example.com


# --- Multi-client limits ---------------------------------------------------
CLIENT_DAILY_QUOTA=1000
CLIENT_MONTHLY_BUDGET=10


# --- Marketplace ------------------------------------------------------------
# Minimum stake (USDC) a provider must keep to remain "approved".
PROVIDER_MIN_STAKE=0.1
# Default slash amount applied on failed validation.
PROVIDER_SLASH_PENALTY=0.05


# --- LLM (OpenAI Responses API) --------------------------------------------
# If OPENAI_API_KEY is set, worker agents route summarize/keywords/rewrite
# tasks through POST /v1/responses. Falls back to the local algorithm on any
# failure. The default model is pinned to a stable gpt-5-nano snapshot.
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-nano-2025-08-07
OPENAI_MAX_OUTPUT_TOKENS=512
# Reasoning effort — one of: none | minimal | low | medium | high | xhigh
# IMPORTANT: do NOT add an inline `# comment` after the value: `node --env-file`
# does not strip it and OpenAI will reject the literal string.
OPENAI_REASONING_EFFORT=low
